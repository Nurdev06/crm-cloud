# ─────────────────────────────────────────────
#  Application Settings
# ─────────────────────────────────────────────
APP_NAME=ClothCRM
APP_ENV=development
DEBUG=true
SECRET_KEY=super-secret-jwt-key-change-in-production-please
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─────────────────────────────────────────────
#  Database
# ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://crmuser:crmpassword@db:5432/crmdb
DATABASE_URL_SYNC=postgresql://crmuser:crmpassword@db:5432/crmdb

# ─────────────────────────────────────────────
#  Redis
# ─────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─────────────────────────────────────────────
#  AWS S3
# ─────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=clothcrm-documents
AWS_CLOUDFRONT_URL=https://cdn.clothcrm.com

# ─────────────────────────────────────────────
#  Email (SMTP)
# ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@clothcrm.com
SMTP_PASSWORD=smtp-password
SMTP_FROM=ClothCRM <noreply@clothcrm.com>

# ─────────────────────────────────────────────
#  Telegram Bot
# ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ─────────────────────────────────────────────
#  Frontend
# ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─────────────────────────────────────────────
#  Postgres (for Docker Compose)
# ─────────────────────────────────────────────
POSTGRES_DB=crmdb
POSTGRES_USER=crmuser
POSTGRES_PASSWORD=crmpassword
